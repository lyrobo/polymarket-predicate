#!/usr/bin/env python3
"""
BTC Predictor Trading Dashboard
================================
Simple web dashboard for displaying Polymarket trading records.
Runs on remote server, reads from synced SQLite database.

Usage:
    python3 dashboard.py [--port PORT] [--db PATH]
"""

import json
import os
import sqlite3
import logging
from http.server import HTTPServer, SimpleHTTPRequestHandler
from datetime import datetime, timezone
from urllib.parse import urlparse, parse_qs

PORT = int(os.environ.get("DASHBOARD_PORT", "8766"))
DB_PATH = os.path.join(os.path.dirname(os.path.abspath(__file__)), "data", "btc_predictor.db")
LOG_DIR = os.path.dirname(os.path.abspath(__file__))

logging.basicConfig(
    level=logging.INFO,
    format='%(asctime)s [%(levelname)s] %(message)s',
    handlers=[
        logging.FileHandler(os.path.join(LOG_DIR, "dashboard.log")),
        logging.StreamHandler(),
    ]
)
logger = logging.getLogger(__name__)


def get_db():
    """Get database connection with Row factory."""
    if not os.path.exists(DB_PATH):
        return None
    conn = sqlite3.connect(DB_PATH)
    conn.row_factory = sqlite3.Row
    return conn


def get_trades(limit=100, offset=0):
    """Get recent trades."""
    conn = get_db()
    if not conn:
        return [], 0
    try:
        cursor = conn.execute(
            "SELECT * FROM real_trades ORDER BY timestamp DESC LIMIT ? OFFSET ?",
            (limit, offset)
        )
        trades = [dict(row) for row in cursor.fetchall()]
        total = conn.execute("SELECT COUNT(*) FROM real_trades").fetchone()[0]
        return trades, total
    except sqlite3.OperationalError:
        return [], 0
    finally:
        conn.close()


def resolve_markets():
    """Resolve markets using CLOB API for accurate settlement results."""
    import urllib.request
    import json
    import time
    
    conn = get_db()
    if not conn:
        return
    
    try:
        # Get matched trades that haven't been resolved
        cursor = conn.execute(
            "SELECT * FROM real_trades WHERE status = 'matched' AND (pnl IS NULL OR pnl = 0)"
        )
        trades = cursor.fetchall()
        
        if not trades:
            return
        
        resolved_count = 0
        for trade in trades:
            t = dict(trade)
            order_id = t.get('order_id', '')
            if not order_id:
                continue
            
            # Query CLOB API for market resolution
            try:
                # Extract market address from order_id (first 42 chars = 0x + 40 hex)
                market_addr = order_id[:42] if len(order_id) >= 42 else ''
                
                if not market_addr or not market_addr.startswith('0x'):
                    continue
                
                url = f"https://clob.polymarket.com/markets/{market_addr}"
                req = urllib.request.Request(url, headers={"User-Agent": "BTC-Predictor/1.0"})
                
                with urllib.request.urlopen(req, timeout=15) as resp:
                    data = json.loads(resp.read().decode())
                    
                    # Check if market is closed and has resolution
                    if not data.get('closed'):
                        continue
                    
                    # Get winning outcome from tokens
                    tokens = data.get('tokens', [])
                    if not tokens:
                        continue
                    
                    # Find winning token
                    winning_outcome = None
                    for token in tokens:
                        if token.get('winner') == True:
                            winning_outcome = token.get('outcome', '')
                            break
                    
                    if not winning_outcome:
                        continue
                    
                    # Determine if trade won
                    direction = t.get('direction', '')
                    size = t.get('size', 0)
                    entry_price = t.get('price', 0)
                    
                    # For BTC up/down markets: outcome is "Up" or "Down"
                    won = (winning_outcome.lower() == direction.lower())
                    
                    # Calculate PnL
                    if won:
                        # Winning shares pay $1 each
                        payout = size * 1.0
                        pnl = payout - (entry_price * size)
                    else:
                        pnl = -(entry_price * size)  # Loss = cost
                    
                    # Update trade
                    conn.execute(
                        "UPDATE real_trades SET pnl = ?, status = 'filled' WHERE id = ?",
                        (round(pnl, 4), t['id'])
                    )
                    resolved_count += 1
                    logger.info(f"Resolved trade {t['id']}: {direction} vs {winning_outcome} (won={won}, pnl={pnl:.2f})")
                    
            except Exception as e:
                logger.warning(f"Failed to resolve trade {t['id']}: {e}")
                continue
        
        if resolved_count > 0:
            conn.commit()
            logger.info(f"Resolved {resolved_count} markets via CLOB API")
        
    except Exception as e:
        logger.error(f"Error resolving markets: {e}")
    finally:
        conn.close()


def get_stats():
    """Get trading statistics."""
    conn = get_db()
    if not conn:
        return {}
    try:
        stats = {}
        
        # Total trades
        # Filled trades (include both 'filled' and 'matched')
        stats["filled_trades"] = conn.execute(
            "SELECT COUNT(*) FROM real_trades WHERE status IN ('filled', 'matched')"
        ).fetchone()[0]
        
        # Total PnL (include both 'filled' and 'matched')
        pnl_row = conn.execute(
            "SELECT COALESCE(SUM(pnl), 0) as total_pnl FROM real_trades WHERE status IN ('filled', 'matched')"
        ).fetchone()
        stats["total_pnl"] = float(pnl_row["total_pnl"])
        
        # Win rate (include both 'filled' and 'matched')
        if stats["filled_trades"] > 0:
            wins = conn.execute(
                "SELECT COUNT(*) FROM real_trades WHERE status IN ('filled', 'matched') AND pnl > 0"
            ).fetchone()[0]
            stats["win_rate"] = round(wins / stats["filled_trades"] * 100, 1)
        else:
            stats["win_rate"] = 0.0
        
        # Recent trades (last 24h)
        yesterday = (datetime.now(timezone.utc) - __import__('datetime').timedelta(days=1)).isoformat()
        stats["trades_24h"] = conn.execute(
            "SELECT COUNT(*) FROM real_trades WHERE timestamp > ?", (yesterday,)
        ).fetchone()[0]
        
        # Average edge (include both 'filled' and 'matched')
        edge_row = conn.execute(
            "SELECT COALESCE(AVG(edge), 0) as avg_edge FROM real_trades WHERE status IN ('filled', 'matched')"
        ).fetchone()
        stats["avg_edge"] = round(float(edge_row["avg_edge"]), 2)
        
        # Direction breakdown
        directions = conn.execute(
            "SELECT direction, COUNT(*) as count FROM real_trades GROUP BY direction"
        ).fetchall()
        stats["directions"] = {row["direction"]: row["count"] for row in directions}
        
        return stats
    except sqlite3.OperationalError:
        return {}
    finally:
        conn.close()


def get_all_trades(limit=50, offset=0, filter_type='all'):
    """Get all trades with filtering and pagination."""
    conn = get_db()
    if not conn:
        return [], 0
    try:
        # Build query based on filter
        base_query = "SELECT * FROM real_trades WHERE 1=1"
        count_query = "SELECT COUNT(*) FROM real_trades WHERE 1=1"
        params = []
        
        if filter_type == 'resolved':
            base_query += " AND status IN ('filled', 'matched')"
            count_query += " AND status IN ('filled', 'matched')"
        elif filter_type == 'open':
            base_query += " AND status = 'live'"
            count_query += " AND status = 'live'"
        elif filter_type == 'UP':
            base_query += " AND direction = 'Up'"
            count_query += " AND direction = 'Up'"
        
        # Get total count
        total = conn.execute(count_query, params).fetchone()[0]
        
        # Get trades
        query = base_query + " ORDER BY timestamp DESC LIMIT ? OFFSET ?"
        cursor = conn.execute(query, params + [limit, offset])
        trades = [dict(row) for row in cursor.fetchall()]
        
        return trades, total
    except sqlite3.OperationalError:
        return [], 0
    finally:
        conn.close()


def get_cycle_history(limit=50):
    """Get recent cycle history."""
    conn = get_db()
    if not conn:
        return []
    try:
        cursor = conn.execute(
            """SELECT cycle, timestamp, direction, edge, our_confidence, status, price
               FROM real_trades 
               ORDER BY timestamp DESC 
               LIMIT ?""",
            (limit,)
        )
        return [dict(row) for row in cursor.fetchall()]
    except sqlite3.OperationalError:
        return []
    finally:
        conn.close()


class DashboardHandler(SimpleHTTPRequestHandler):
    """HTTP request handler for the dashboard."""
    
    def do_GET(self):
        parsed = urlparse(self.path)
        
        # Resolve markets before serving data
        resolve_markets()
        
        if parsed.path == "/" or parsed.path == "/index.html":
            self.serve_dashboard()
        elif parsed.path == "/api/trades":
            params = parse_qs(parsed.query)
            limit = int(params.get("limit", [100])[0])
            offset = int(params.get("offset", [0])[0])
            trades, total = get_trades(limit, offset)
            self.send_json({"trades": trades, "total": total})
        elif parsed.path == "/api/stats":
            stats = get_stats()
            self.send_json(stats)
        elif parsed.path == "/api/cycles":
            params = parse_qs(parsed.query)
            limit = int(params.get("limit", [50])[0])
            cycles = get_cycle_history(limit)
            self.send_json({"cycles": cycles})
        elif parsed.path == "/api/all_trades":
            params = parse_qs(parsed.query)
            limit = int(params.get("limit", [50])[0])
            offset = int(params.get("offset", [0])[0])
            filter_type = params.get("filter", ["all"])[0]
            trades, total = get_all_trades(limit, offset, filter_type)
            self.send_json({"trades": trades, "total": total})
        elif parsed.path == "/api/health":
            self.send_json({
                "status": "ok",
                "db_exists": os.path.exists(DB_PATH),
                "timestamp": datetime.now(timezone.utc).isoformat()
            })
        else:
            self.send_error(404)
    
    def serve_dashboard(self):
        """Serve the main dashboard HTML."""
        html = """<!DOCTYPE html>
<html lang="zh-CN">
