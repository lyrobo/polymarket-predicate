    <script>
        const API_BASE = window.location.origin;
        
        async function fetchJSON(path) {
            const res = await fetch(API_BASE + path);
            return res.json();
        }
        
        function formatTime(iso) {
            if (!iso) return '--';
            const d = new Date(iso);
            return d.toLocaleString('zh-CN', { 
                month: '2-digit', day: '2-digit',
                hour: '2-digit', minute: '2-digit', second: '2-digit'
            });
        }
        
        function formatNumber(num, decimals = 2) {
            if (num == null || isNaN(num)) return '--';
            return Number(num).toFixed(decimals);
        }
        
        async function loadStats() {
            try {
                const stats = await fetchJSON('/api/stats');
                const grid = document.getElementById('stats-grid');
                
                const pnlClass = stats.total_pnl >= 0 ? 'positive' : 'negative';
                
                grid.innerHTML = `
                    <div class="stat-card">
                        <div class="label">Total Trades</div>
                        <div class="value neutral">${stats.total_trades || 0}</div>
                    </div>
                    <div class="stat-card">
                        <div class="label">Filled Trades</div>
                        <div class="value neutral">${stats.filled_trades || 0}</div>
                    </div>
                    <div class="stat-card">
                        <div class="label">Win Rate</div>
                        <div class="value ${stats.win_rate >= 50 ? 'positive' : 'negative'}">${stats.win_rate || 0}%</div>
                    </div>
                    <div class="stat-card">
                        <div class="label">Total PnL</div>
                        <div class="value ${pnlClass}">$${formatNumber(stats.total_pnl)}</div>
                    </div>
                    <div class="stat-card">
                        <div class="label">Trades (24h)</div>
                        <div class="value neutral">${stats.trades_24h || 0}</div>
                    </div>
                    <div class="stat-card">
                        <div class="label">Avg Edge</div>
                        <div class="value ${stats.avg_edge >= 0 ? 'positive' : 'negative'}">${stats.avg_edge || 0}%</div>
                    </div>
                `;
            } catch (e) {
                console.error('Failed to load stats:', e);
            }
        }
        
        async function loadTrades() {
            try {
                const data = await fetchJSON('/api/trades?limit=20');
                const tbody = document.getElementById('trades-body');
                
                if (!data.trades || data.trades.length === 0) {
                    tbody.innerHTML = '<tr><td colspan="8" style="text-align:center; color:#8892b0;">No trades yet. Waiting for first trade...</td></tr>';
                    return;
                }
                
                tbody.innerHTML = data.trades.map(t => `
                    <tr>
                        <td>${formatTime(t.timestamp)}</td>
                        <td><span class="badge ${t.direction ? t.direction.toLowerCase() : 'hold'}">${t.direction || 'HOLD'}</span></td>
                        <td>$${formatNumber(t.price)}</td>
                        <td>${formatNumber(t.size)}</td>
                        <td class="${t.edge >= 0 ? 'positive' : 'negative'}">${formatNumber(t.edge)}%</td>
                        <td>${formatNumber(t.our_confidence)}%</td>
                        <td><span class="badge ${t.status}">${t.status || '--'}</span></td>
                        <td class="${t.pnl >= 0 ? 'positive' : 'negative'}">$${formatNumber(t.pnl)}</td>
                    </tr>
                `).join('');
            } catch (e) {
                console.error('Failed to load trades:', e);
            }
        }
        
        async function loadCycles() {
            try {
                const data = await fetchJSON('/api/cycles?limit=30');
                const tbody = document.getElementById('cycles-body');
                
                if (!data.cycles || data.cycles.length === 0) {
                    tbody.innerHTML = '<tr><td colspan="7" style="text-align:center; color:#8892b0;">No cycles recorded yet...</td></tr>';
                    return;
                }
                
                tbody.innerHTML = data.cycles.map(c => `
                    <tr>
                        <td>#${c.cycle || '--'}</td>
                        <td>${formatTime(c.timestamp)}</td>
                        <td>$${formatNumber(c.price)}</td>
                        <td><span class="badge ${c.direction ? c.direction.toLowerCase() : 'hold'}">${c.direction || 'HOLD'}</span></td>
                        <td class="${c.edge >= 0 ? 'positive' : 'negative'}">${formatNumber(c.edge)}%</td>
                        <td>${formatNumber(c.our_confidence)}%</td>
                        <td>${c.status === 'filled' ? '✅ Trade' : '⏸ Hold'}</td>
                    </tr>
                `).join('');
            } catch (e) {
                console.error('Failed to load cycles:', e);
            }
        }
        
        // All Trades table state
        let allTradesPage = 0;
        let allTradesFilter = 'all';
        const ALL_TRADES_PER_PAGE = 50;
        
        function filterAllTrades(filter) {
            allTradesFilter = filter;
            allTradesPage = 0;
            // Update button states
            document.querySelectorAll('.filter-btn').forEach(btn => btn.classList.remove('active'));
            const btnId = 'filter-' + filter;
            const btn = document.getElementById(btnId);
            if (btn) btn.classList.add('active');
            loadAllTradesPage(0);
        }
        
        function loadAllTradesPage(direction) {
            if (direction === -1 && allTradesPage > 0) allTradesPage--;
            else if (direction === 1) allTradesPage++;
            else if (direction === 0) allTradesPage = 0;
            
            const offset = allTradesPage * ALL_TRADES_PER_PAGE;
            const url = `/api/all_trades?limit=${ALL_TRADES_PER_PAGE}&offset=${offset}&filter=${allTradesFilter}`;
            
            fetchJSON(url).then(data => {
                const tbody = document.getElementById('all-trades-body');
                const totalEl = document.getElementById('all-trades-total');
                const rangeEl = document.getElementById('all-trades-range');
                const pageEl = document.getElementById('all-trades-page');
                
                totalEl.textContent = data.total;
                
                const trades = data.trades || [];
                const totalPages = Math.ceil(data.total / ALL_TRADES_PER_PAGE);
                pageEl.textContent = `Page ${allTradesPage + 1} / ${totalPages}`;
                
                const startNum = offset + 1;
                const endNum = Math.min(offset + trades.length, data.total);
                rangeEl.textContent = `Showing ${startNum}-${endNum} of ${data.total}`;
                
                if (trades.length === 0) {
                    tbody.innerHTML = '<tr><td colspan="8" style="text-align:center; color:#8892b0;">No trades found</td></tr>';
                    return;
                }
                
                tbody.innerHTML = trades.map((t, idx) => {
                    const pnlColor = t.pnl >= 0 ? 'positive' : 'negative';
                    const statusColor = t.status === 'live' ? '#ffd740' : '#6b7a8d';
                    const dirColor = t.direction === 'Up' ? '#00e676' : '#ff5252';
                    const num = data.total - (allTradesPage * ALL_TRADES_PER_PAGE) - idx;
                    
                    return `
                        <tr>
                            <td style="color:#8892b0;">${num}</td>
                            <td style="color:#8892b0;">${formatTime(t.timestamp)}</td>
                            <td style="color:${dirColor}; font-weight:600;">${t.direction || '--'}</td>
                            <td>$${formatNumber(t.size * t.price)}</td>
                            <td style="color:#8892b0;">$${formatNumber(t.price)}</td>
                            <td style="color:#ffd740; font-weight:600;">${t.price > 0 ? (1/t.price).toFixed(2) : '--'}x</td>
                            <td style="color:${pnlColor}; font-weight:600;">${t.pnl != null ? (t.pnl >= 0 ? '+' : '') + formatNumber(t.pnl) : '--'}</td>
                            <td style="color:${statusColor};">${(t.status || '--').toUpperCase()}</td>
                        </tr>
                    `;
                }).join('');
            }).catch(e => console.error('Failed to load all trades:', e));
        }
        
        async function checkHealth() {
            try {
                const health = await fetchJSON('/api/health');
                const badge = document.getElementById('status-badge');
                if (health.db_exists) {
                    badge.className = 'status online';
                    badge.textContent = '● LIVE';
                } else {
                    badge.className = 'status offline';
                    badge.textContent = '● DB NOT FOUND';
                }
                document.getElementById('last-sync').textContent = formatTime(health.timestamp);
            } catch (e) {
                console.error('Health check failed:', e);
            }
        }
        
        async function refreshAll() {
            await Promise.all([loadStats(), loadTrades(), loadCycles(), checkHealth()]);
            loadAllTradesPage(0);
        }
        
        // Initial load
        refreshAll();
        loadAllTradesPage(0);
        
        // Auto-refresh every 30 seconds
        setInterval(refreshAll, 30000);
        setInterval(() => loadAllTradesPage(0), 30000);
    </script>
</body>
</html>"""
        self.send_response(200)
        self.send_header('Content-Type', 'text/html; charset=utf-8')
        self.end_headers()
        self.wfile.write(html.encode('utf-8'))
    
    def send_json(self, data):
        """Send JSON response."""
        body = json.dumps(data, ensure_ascii=False).encode('utf-8')
        self.send_response(200)
        self.send_header('Content-Type', 'application/json')
        self.send_header('Content-Length', str(len(body)))
        self.end_headers()
        self.wfile.write(body)


def main():
    import argparse
    global DB_PATH, PORT  # Move global declaration to the beginning
    
    parser = argparse.ArgumentParser(description='BTC Predictor Trading Dashboard')
    parser.add_argument('--port', type=int, default=PORT, help='Port to run on')
    parser.add_argument('--db', type=str, default=DB_PATH, help='Database path')
    args = parser.parse_args()
    
    DB_PATH = args.db
    PORT = args.port
    
    logger.info(f"Starting BTC Predictor Dashboard on port {PORT}")
    logger.info(f"Database: {DB_PATH}")
    
    server = HTTPServer(('0.0.0.0', PORT), DashboardHandler)
    logger.info(f"Dashboard running at http://0.0.0.0:{PORT}")
    
    try:
        server.serve_forever()
    except KeyboardInterrupt:
        logger.info("Dashboard stopped")
        server.shutdown()


if __name__ == "__main__":
    main()
