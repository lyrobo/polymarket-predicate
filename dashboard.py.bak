                </thead>
                <tbody id=\"trades-body\">
                    <tr><td colspan=\"8\" class=\"loading\">Loading trades...</td></tr>
                </tbody>
            </table>
        </div>
        
        <!-- All Trades -->
        <div class=\"table-container\">
            <div class=\"table-title\">📋 All Trades (<span id=\"all-trades-total\">0</span>)</div>
            <div style=\"margin-bottom:12px;display:flex;align-items:center;gap:12px;flex-wrap:wrap;\">
                <span style=\"color:#8892b0;font-size:12px;\">Filter:</span>
                <button onclick=\"filterAllTrades('all')\" id=\"filter-all\" class=\"filter-btn active\">All</button>
                <button onclick=\"filterAllTrades('resolved')\" id=\"filter-resolved\" class=\"filter-btn\">Resolved</button>
